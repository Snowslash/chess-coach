# Copy this to .env.stockfish or export these variables in your shell.
# Do not commit .env.stockfish or any machine-specific env file.

# Path to a locally installed Stockfish binary.
# Stockfish is GPL-3.0 and must not be vendored into this repository.
export STOCKFISH_PATH=/path/to/stockfish
export STOCKFISH_DEPTH=12
export STOCKFISH_TIME_LIMIT=0.1

# Optional Maia 2 human-likeness analysis.
# Keep model weights/assets local and out of git; install/runtime licensing must be checked separately.
export MAIA2_ENABLED=false
export MAIA2_GAME_TYPE=rapid
export MAIA2_DEVICE=cpu
export MAIA2_TARGET_ELO=1500

# Optional defaults for scripts/run_report.sh.
export CHESS_COACH_PGN=input/sample_games.pgn
export CHESS_COACH_OUT=reports/latest.md
export CHESS_COACH_PLAYER=your_lichess_username
